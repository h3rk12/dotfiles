{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

 read -n1 -p "Do you install Homebrew? (y/N): " yn
 case "$yn" in
   [yY]*) /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)";;
   *) echo "abort";;
esac

 read -n1 -p "Run brew bundle? (y/N): " yn
 case "$yn" in
   [yY]*) brew bundle --file="$HOME/.Brewfile";;
   *) echo "abort";;
esac

 read -n1 -p "Run wt config shell install? (y/N): " yn
 case "$yn" in
   [yY]*) wt config shell install;;
   *) echo "abort";;
esac

 read -n1 -p "Run rtk init -g? (y/N): " yn
 case "$yn" in
   [yY]*) rtk init -g;;
   *) echo "abort";;
esac

{{ end -}}
